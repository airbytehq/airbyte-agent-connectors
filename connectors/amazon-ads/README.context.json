        "type": "str",
        "schema": {
          "type": "string",
          "default": "seller,vendor"
        },
        "required": null,
        "description": "Filter profiles by type. Comma-separated list of profile types.\nValid values: seller, vendor, agency\n",
        "is_deep_object": false
      }
